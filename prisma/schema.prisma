// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/////////////////////////////////////////////////
// ENUMS
////////////////////////////////////////////////

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ABERTO
  FECHADO
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/////////////////////////////////////////////////
// CORE MODELS
////////////////////////////////////////////////

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       Member[]
  createdProjects   Project[]
  createdTasks      Task[]           @relation("TaskCreatedBy")
  assignedTasks     TaskAssignments[] @relation("TaskAssignedBy")
  createdDocuments  Document[]
  refreshTokens     RefreshToken[]
}

model RefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  userId      String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
  projects  Project[]
  tasks     Task[]
  documents Document[]
}

model Member {
  id             String   @id @default(uuid())
  role           Role
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  organizationId String

  user           User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectMemberships ProjectMember[]

  @@unique([userId, organizationId])
  // Note: Partial unique constraint for OWNER role enforced via migration
  // CREATE UNIQUE INDEX unique_owner_per_org ON "Member"("organizationId", "role") WHERE "role" = 'OWNER';
  @@index([organizationId])
}

/////////////////////////////////////////////////
// PROJECT
////////////////////////////////////////////////

model Project {
  id             String        @id @default(uuid())
  name           String
  description    String?
  status         ProjectStatus @default(ABERTO)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organizationId String
  createdById    String

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User          @relation(fields: [createdById], references: [id])

  projectMembers ProjectMember[]
  taskStatuses   TaskStatus[]
  tasks          Task[]
  documents      Document[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  addedAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  memberId  String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    Member  @relation(fields: [memberId], references: [id])

  taskAssignments TaskAssignments[]
  documentsLocks  DocumentLock[]

  @@unique([projectId, memberId])
  @@index([projectId])
}

/////////////////////////////////////////////////
// TASKS & KANBAN
////////////////////////////////////////////////

model TaskStatus {
  id        String   @id @default(uuid())
  name      String
  position  Int
  color     String?
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks     Task[]

  @@unique([projectId, position])
  @@index([projectId])
}

model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projectId      String
  statusId       String
  organizationId String
  createdById    String

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status         TaskStatus   @relation(fields: [statusId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdBy      User         @relation("TaskCreatedBy", fields: [createdById], references: [id])

  assignments    TaskAssignments[]

  @@index([projectId])
  @@index([organizationId])
  @@index([statusId])
  @@index([projectId, statusId])
  @@index([dueDate])
}

model TaskAssignments {
  id              String   @id @default(uuid())
  assignedAt      DateTime @default(now())

  taskId          String
  projectMemberId String
  assignedById    String

  task            Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectMember   ProjectMember @relation(fields: [projectMemberId], references: [id])
  assignedBy      User          @relation("TaskAssignedBy", fields: [assignedById], references: [id])

  @@unique([taskId, projectMemberId])
  @@index([taskId])
  @@index([projectMemberId])
}

/////////////////////////////////////////////////
// DOCUMENTS
////////////////////////////////////////////////

model Document {
  id             String   @id @default(uuid())
  title          String
  content        Json     @db.JsonB
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId      String
  organizationId String
  createdById    String

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdBy      User          @relation(fields: [createdById], references: [id])

  lock           DocumentLock?

  @@index([projectId])
  @@index([organizationId])
}

model DocumentLock {
  id                String        @id @default(uuid())
  lockedAt          DateTime      @default(now())
  expiresAt         DateTime

  documentId        String        @unique
  projectMemberId   String

  document          Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  projectMember     ProjectMember @relation(fields: [projectMemberId], references: [id])

  @@index([expiresAt])
  @@index([projectMemberId])
}

model DocumentDeletionLog {
  id         String   @id @default(uuid())
  documentId String
  deletedBy  String
  deletedAt  DateTime @default(now())
}
